{
    "compilerOptions": {
      "outDir": "./dist/",
      "noImplicitAny": true,
      "module": "NodeNext",
      "target": "ESNext",
      "jsx": "react",
      "allowJs": true,
      "moduleResolution": "nodenext",
      "sourceMap": true,
      "strict": true,
      "noUnusedLocals": true,
      "noUnusedParameters": true,
      "esModuleInterop": true,
      "forceConsistentCasingInFileNames": true,
      "skipLibCheck": true,
      "noEmit": false,
      "resolveJsonModule": true,
      "baseUrl": ".",
      "paths": {
        "@/*": ["shadcn/*"]
      }
    }
  }